#!/bin/bash
# Heavily inspired by https://github.com/rehanzo/swayhide
# Adds support for executing commands as root

command_args=("$@")

# Get current window id
conid=$(swaymsg -t get_tree | jq '.. | select(.type?) | select(.focused==true) | .id')

if [[ -z "$conid" ]]; then
    echo "No focused window found." >&2
    exit 1
fi

# Wait for the new window to be spawned, use redirect to subshell to get the pid of swaymsg
swaymsg -m -t subscribe '["window"]' > >(
    first=1
    jq --unbuffered -cr 'select(.change == "new")' | \
    while read -r line; do
        if [[ $first -eq 1 ]]; then
            swaymsg "[con_id=$conid] focus; move scratchpad" >/dev/null
            swaymsg "split none" >/dev/null
            first=0
        fi
    done
) &
swaymsg_id=$!

swaymsg "split v" >/dev/null

"${command_args[@]}" &
process_id=$!

wait "$process_id"
exit_code=$?

if [[ $exit_code -ne 0 ]]; then
    echo "swayhide: command exited with code: $exit_code" >&2
fi

swaymsg "[con_id=$conid] focus; floating disable" >/dev/null

kill "$swaymsg_id" 2>/dev/null
wait "$swaymsg_id" 2>/dev/null