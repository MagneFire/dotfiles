[{
    "layer": "top",
    "position": "top",
    "height": 37,
    "name": "mainbar",
    "output": "eDP-1",
    "modules-left": [
        "hyprland/workspaces",
        "sway/workspaces",
        "sway/mode",
        "custom/playerctl"
    ],
    "modules-center": [
        "cava"
    ],
    "modules-right": [
        "battery",
        "custom/notifications",
        "tray",
        "privacy",
        "group/brightness",
        "custom/powermenu",
        "clock"
    ],
    "sway/mode": {
        "format": "\udb80\udf35 {}",
        "max-length": 50
    },
    "group/brightness": {
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 500,
            "transition-left-to-right": false
        },
        "modules": [
            "custom/brightness",
            "backlight/slider"
        ]
    },
    "cava": {
        "framerate": 30,
        "autosens": 1,
        "bars": 35,
        "method": "pipewire",
        "source": "auto",
        "bar_delimiter": 0,
        "input_delay": 2,
        "sleep_timer": 2,
        "hide_on_silence": true,
        "format-icons" : ["Ôûü", "Ôûé", "Ôûâ", "Ôûä", "Ôûà", "Ôûå", "Ôûç", "Ôûê" ]
    },
    "backlight/slider": {
        "min": 1
    },
    "custom/brightness": {
        "format": "¾░âá",
        "tooltip": false
    },
    "sway/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "default": "´Æ¬",
            "focused": "´åÆ"
        },
        "on-click": "activate",
        "sort-by-number": true
    },
    "hyprland/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "default": "´Æ¬",
            "active": "´åÆ"
        },
        "on-scroll-up": "hyprctl dispatch workspace e+1",
        "on-scroll-down": "hyprctl dispatch workspace e-1",
        "on-click": "activate",
        "sort-by-number": true
    },
    "bluetooth": {
        "format": "´èö",
        "on-click": "blueman-manager"
    },
    "privacy": {
        "icon-spacing": 2,
        "icon-size": 18,
        "modules": [
        {
            "type": "screenshare"
        },
        {
            "type": "audio-in"
        }
        ]
    },
    "custom/maximized": {
        "format": "{}",
        "return-type": "json",
        "exec": "~/.config/waybar/scripts/maximized.sh"
    },
    "custom/notifications": {
        "format": "{}",
        "return-type": "json",
        "exec": "~/.config/waybar/scripts/notification.sh",
        "on-click": "swaync-client -t -sw"
    },
    "custom/playerctl": {
        "format": "{icon} <span>{0}</span>",
        "return-type": "json",
        "max-length": 50,
        "exec": "$HOME/.config/waybar/scripts/mediaplayer.py 2> /dev/null",
        "on-click-middle": "playerctl play-pause",
        "on-click": "playerctl previous",
        "on-click-right": "playerctl next",
        "format-icons": {
            "Playing": "<span>´üï</span>",
            "Paused": "<span>´üî</span>"
        }
    },
    "tray": {
        "icon-size": 21,
        "spacing": 10
    },
    "clock": {
        "format": "{:%d %B %R}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d}",
        "actions": {
            "on-click": "mode"
        }
    },
    "cpu": {
        "format": "´ïø  {usage}%",
        "tooltip": false
    },
    "backlight": {
        "on-scroll-up": "light -A 12",
        "on-scroll-down": "light -U 12",
        "format": "{icon}",
        "format-icons": [
            "¾░âŞ ",
            "¾░âØ ",
            "¾░âş ",
            "¾░âá "
        ]
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "¾░éä {capacity}%",
        "format-full": "¾░ü╣ {capacity}%",
        "format-icons": [
            "¾░ü║",
            "¾░ü╝",
            "¾░ü¥",
            "¾░éÇ",
            "¾░ü╣"
        ]
    },
    "custom/powermenu": {
        "format": "´Çæ",
        "on-click": "anyrun --hide-plugin-info=true --show-results-immediately=true --plugins libpowermenu.so",
        "tooltip": false
    }
},
{
    "layer": "top",
    "position": "top",
    "height": 1,
    "name": "secondary-bar",
    "output": "!eDP-1",
    "modules-center": [
        "hyprland/workspaces#secondary",
        "sway/workspaces#secondary"
    ]
}]
